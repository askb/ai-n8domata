## Autoscaling
COMPOSE_PROJECT_NAME=n8n-autoscaling-ag15
COMPOSE_FILE_PATH=/app/docker-compose.yml
GENERIC_TIMEZONE=America/New_York
MIN_REPLICAS=1
# Worker autoscaling cap. Set to 1 to SERIALIZE heavy jobs (single BullMQ worker ->
# one concurrent execution) so the host isn't overloaded; raise for more parallelism.
# Production runtime currently uses 1.
MAX_REPLICAS=5
SCALE_UP_QUEUE_THRESHOLD=5
SCALE_DOWN_QUEUE_THRESHOLD=1
POLLING_INTERVAL_SECONDS=10
COOLDOWN_PERIOD_SECONDS=10
POLL_INTERVAL_SECONDS=5
N8N_QUEUE_BULL_GRACEFULSHUTDOWNTIMEOUT=300
N8N_GRACEFUL_SHUTDOWN_TIMEOUT=300

## Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
QUEUE_NAME_PREFIX=bull
QUEUE_NAME=jobs
QUEUE_BULL_REDIS_HOST=redis
QUEUE_HEALTH_CHECK_ACTIVE=true

## Postgres
POSTGRES_HOST=postgres
POSTGRES_DB=n8n
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
PGDATA=/var/lib/postgresql/data/pgdata
DB_TYPE=postgresdb

## N8N
N8N_HOST=n8n-ag15.askb.dev
N8N_WEBHOOK=n8n-ag15.askb.dev
N8N_WEBHOOK_URL=https://n8n-ag15.askb.dev/webhook
WEBHOOK_URL=https://n8n-ag15.askb.dev
N8N_EDITOR_BASE_URL=https://n8n-ag15.askb.dev
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_DIAGNOSTICS_ENABLED=false
N8N_USER_FOLDER=/n8n/main
N8N_SECURE_COOKIE=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
N8N_PATH=/
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_DISABLE_UI=false
N8N_PUSH_BACKEND=websocket
N8N_ENCRYPTION_KEY=CHANGE_ME
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME
N8N_WORKER_SERVICE_NAME=n8n-worker
EXECUTIONS_MODE=queue
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
N8N_TASK_BROKER_URL=http://n8n:5679
N8N_COMMAND_RESPONSE_URL=http://n8n:5679
N8N_TASK_BROKER_PORT=5679
N8N_RUNNERS_AUTH_TOKEN=CHANGE_ME
NODE_FUNCTION_ALLOW_EXTERNAL=ajv,ajv-formats,puppeteer,ffmpeg,git,graphicsmagick,openssh-client

# n8n 2.x disables ExecuteCommand and LocalFileTrigger by default.
# Override with empty array to re-enable for workflows that need them.
NODES_EXCLUDE=[]
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# nca-toolkit base URL. Workflows reference {{ $env.NCA_BASE_URL || '<public-url>' }}
# so service-to-service calls use the in-cluster endpoint (bypassing Cloudflare).
# Leave unset to fall back to the public URL baked into the workflows.
NCA_BASE_URL=http://nca-toolkit:8080
# n8n 2.x blocks $env access in node expressions by default; set false to allow
# workflows to read NCA_BASE_URL (and other env) in expressions. Single-operator
# instance only -- any workflow expression can then read process env.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Add these to your .env file to prevent the 28GB table issue from happening again
# N8N Data Retention Settings

# Execution data retention (prevents 28GB tables!)
N8N_EXECUTIONS_DATA_PRUNE=true
N8N_EXECUTIONS_DATA_MAX_AGE=300          # 7 days (168 hours)
N8N_EXECUTIONS_DATA_PRUNE_MAX_COUNT=5000  # Max 5000 executions kept
N8N_EXECUTIONS_DATA_PRUNE_TIMEOUT=3600   # 1 hour timeout for pruning
N8N_PAYLOAD_SIZE_MAX=1048576

# Binary data cleanup (also important)
N8N_BINARY_DATA_TTL=720                  # 12 hours (720 minutes)

# Success executions (keep fewer successful ones)
N8N_EXECUTIONS_DATA_SAVE_ON_SUCCESS=last  # Only save the last successful execution

# Error executions (keep more for debugging)
N8N_EXECUTIONS_DATA_SAVE_ON_ERROR=all     # Keep all error executions for debugging

# Manual executions (save all for development)
N8N_EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true

# Production vs Development settings
# For PRODUCTION, use these more aggressive settings:
# N8N_EXECUTIONS_DATA_MAX_AGE=72         # 3 days only
# N8N_EXECUTIONS_DATA_PRUNE_MAX_COUNT=1000
# N8N_EXECUTIONS_DATA_SAVE_ON_SUCCESS=none

# For DEVELOPMENT (current setup), the above settings are good
# Additional performance settings
N8N_EXECUTIONS_DATA_PRUNE_HARD_DELETE_BUFFER=100
N8N_EXECUTIONS_DATA_PRUNE_HARD_DELETE_INTERVAL=15

## for short-video-maker
PEXELS_API_KEY=CHANGE_ME
SHORT_VIDEO_MAKER_HOST=short-video-maker.askb.dev

